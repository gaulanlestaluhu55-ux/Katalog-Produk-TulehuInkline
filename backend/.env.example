# Copy file ini jadi .env kalau mau jalanin migrate-from-gas.js di komputer lokal.
# Buat di Vercel sendiri, variable ini di-set lewat Dashboard > Project > Settings > Environment Variables
# (JANGAN upload file .env asli ke GitHub)

# Dari Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi-dengan-service-role-key-JANGAN-anon-key

# Token admin — samain persis kayak ADMIN_TOKEN yang dulu dipakai di GAS (Moluccan98 kalau belum diganti)
ADMIN_TOKEN=Moluccan98

# Khusus buat scripts/migrate-from-gas.js — URL Web App GAS yang LAMA (masih harus aktif pas migrasi jalan)
OLD_GAS_URL=https://script.google.com/macros/s/xxxxxxxxxxxx/exec
