# Copy file ini jadi .env kalau mau jalanin migrate-from-gas.js di komputer lokal.
# Buat di Vercel sendiri, variable ini di-set lewat Dashboard > Project > Settings > Environment Variables
# (JANGAN upload file .env asli ke GitHub)

# Dari Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Isi dengan token admin random yang kuat
ADMIN_TOKEN=

# Khusus buat scripts/migrate-from-gas.js — URL Web App GAS yang lama
OLD_GAS_URL=https://your-old-gas-url.example.com
